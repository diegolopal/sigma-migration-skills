  "data_elements": [
    {
      "id": "el-win-window-maxmin-win-src",
      "kind": "table",
      "name": "Net Revenue Window Source (win-window-maxmin)",
      "source": {
        "kind": "table",
        "elementId": "master"
      },
      "columns": [
        {
          "id": "el-win-window-maxmin-win-src-p0",
          "name": "Region",
          "formula": "[Master/Region]"
        },
        {
          "id": "el-win-window-maxmin-win-src-a0",
          "name": "Order Date",
          "formula": "DateTrunc(\"quarter\", [Master/Order Date])"
        },
        {
          "id": "el-win-window-maxmin-win-src-v",
          "name": "Net Revenue Window Base",
          "formula": "Sum([Master/Net Revenue])"
        },
        {
          "id": "el-win-window-maxmin-win-src-s0",
          "name": "Window Max Revenue",
          "formula": "Max([Net Revenue Window Base])"
        },
        {
          "id": "el-win-window-maxmin-win-src-s1",
          "name": "Window Min Revenue",
          "formula": "Min([Net Revenue Window Base])"
        }
      ],
      "groupings": [
