{
  "pages": [
    {
      "name": "[synthetic] WIN Running Revenue",
      "elements": [
        {
          "id": "title--synthetic-win-running-revenue",
          "kind": "text",
          "body": "# <span style=\"color: #FFFFFF\">[synthetic] WIN Running Revenue</span>"
        },
        {
          "id": "el-win-running-revenue",
          "kind": "line-chart",
          "name": "WIN Running Revenue",
          "source": {
            "kind": "table",
            "elementId": "master"
          },
          "columns": [
            {
              "id": "x-el-win-running-revenue",
              "name": "Order Date",
              "formula": "DateAdd(\"day\", 1 - Weekday([Master/Order Date]), DateTrunc(\"day\", [Master/Order Date]))",
              "format": {
                "kind": "datetime",
                "formatString": "%b %d, %Y"
              }
            },
            {
              "id": "y-el-win-running-revenue",
              "name": "Running Revenue",
              "formula": "CumulativeSum(Sum([Master/Net Revenue]))",
              "format": {
                "kind": "number",
                "formatString": "$,.0f",
                "currencySymbol": "$"
              }
            },
            {
              "id": "nn-x-el-win-running-revenue",
              "name": "Order Date Not Null",
              "formula": "IsNotNull(DateAdd(\"day\", 1 - Weekday([Master/Order Date]), DateTrunc(\"day\", [Master/Order Date])))"
            }
          ],
          "xAxis": {
            "columnId": "x-el-win-running-revenue"
          },
          "yAxis": {
            "columnIds": [
              "y-el-win-running-revenue"
            ]
          },
          "filters": [
            {
              "columnId": "nn-x-el-win-running-revenue",
              "kind": "list",
              "mode": "include",
              "selectionMode": "multiple",
              "values": [
                true
              ],
              "id": "flt-el-win-running-revenue-0"
            }
          ]
        }
      ]
    },
