                "formula": "[ORDER_FACT/Gross Profit]"
              },
              {
                "id": "inode-NORM0018/DISCOUNT_AMOUNT",
                "formula": "[ORDER_FACT/Discount Amount]"
              },
              {
                "id": "inode-NORM0019/QUANTITY_ORDERED",
                "formula": "[ORDER_FACT/Quantity Ordered]"
              },
              {
                "id": "inode-NORM0020/QUANTITY_RETURNED",
