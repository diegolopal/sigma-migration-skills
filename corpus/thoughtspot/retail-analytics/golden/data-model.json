              },
              {
                "id": "inode-NORM0021/DAYS_TO_SHIP",
                "formula": "[ORDER_FACT/Days to Ship]"
              },
              {
                "id": "id0022",
                "name": "Gross Margin Pct",
                "formula": "If( [Gross Revenue] > 0 , [Gross Profit] / [Gross Revenue], 0)",
                "format": {
                  "kind": "number",
                  "formatString": ",.2f",
                  "suffix": "%"
                }
              },
              {
                "id": "id0023",
                "name": "Channel Group",
                "formula": "If( In([Order Channel], \"EMAIL\", \"SMS\") , \"Digital Direct\", If( In([Order Channel], \"STORE\") , \"In-Store\", \"Other\"))"
              },
              {
                "id": "id0024",
                "name": "Avg Order Value",
                "formula": "If(IsNull([Quantity Ordered]) or [Quantity Ordered] = 0, null, [Gross Revenue] / [Quantity Ordered])",
                "format": {
                  "kind": "number",
                  "formatString": "$,.2f",
                  "currencySymbol": "$"
                }
              }
            ],
            "metrics": [
              {
                "id": "id0025",
                "name": "Gross Revenue",
                "formula": "Sum([Gross Revenue])",
                "format": {
